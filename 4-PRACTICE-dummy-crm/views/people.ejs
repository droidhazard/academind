<%- include('./includes/head.ejs') %>
  <body>
    <%- include('./includes/navigation.ejs') %>

    <main class="main-container">
      <form action="/people" method="POST" class="form-container">
        <h2>Add a contact</h2>
        <input type="text" name="firstname" placeholder="First name" />
        <input type="text" name="lastname" placeholder="Last name" />
        <input type="text" name="address" placeholder="Address" />
        <input type="text" name="email" placeholder="Email" />
        <input type="text" name="phone" placeholder="Phone" />
        <button type="submit" class="submit">Create Contact</button>
      </form>

      <div class="card-container">
        <% if (peopleArray.length > 0) { %>
          <% for (let item of peopleArray) { %>
            <div class="card">
              <img src="contact.png" alt="contact icon" />
              <section>
                <p class="card-text-primary"><%= item.firstname + " " + item.lastname %></p>
                <p class="card-text-secondary"><%= item.email %></p>
                <p class="card-text-secondary"><%= item.address %></p>
              </section>
            </div>
          <% } %>
        <% } else { %>
          <h2 style="color:white;">Add some people to get started...</h2>
        <% } %>
      </div>
    </main>
<%- include('./includes/end.ejs') %>
